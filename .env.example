# Exemplo de variáveis de ambiente.
# O projeto roda localmente sem segredos obrigatórios, mas os fluxos abaixo usam credenciais.

# Dadosfera Maestro API
DADOSFERA_ENABLED=false
DADOSFERA_MAESTRO_BASE_URL=https://maestro.dadosfera.ai
DADOSFERA_ACCESS_TOKEN=
DADOSFERA_API_TOKEN=
DADOSFERA_USERNAME=
DADOSFERA_PASSWORD=
DADOSFERA_TOTP=
DADOSFERA_PIPELINE_LIST_ENDPOINT=/platform/pipelines
DADOSFERA_PIPELINE_CREATE_ENDPOINT=/platform/pipeline
DADOSFERA_PIPELINE_GET_ENDPOINT_TEMPLATE=/platform/pipeline/{pipeline_id}
DADOSFERA_PIPELINE_RUN_ENDPOINT=/platform/pipeline/execute
DADOSFERA_PIPELINE_RUNS_ENDPOINT_TEMPLATE=/platform/pipeline/{pipeline_id}/pipeline_run

# OpenAI API
OPENAI_ENABLED=false
OPENAI_API_KEY=

# Snowflake
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_ROLE=PUBLIC

# Logging
LOG_FORMAT=text
