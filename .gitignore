data/platform.duckdb

# Keep raw data delivered with the case
!data/raw/
!data/raw/landing/
!data/raw/landing/olist/

# Ignore generated Data Lake layers
data/standardized/*
!data/standardized/.gitkeep

data/staging/*
!data/staging/.gitkeep

data/curated/*
!data/curated/.gitkeep
!data/curated/catalog/
!data/curated/catalog/*.json
!data/curated/catalog/*.csv
!data/curated/genai/
!data/curated/genai/*.csv
!data/curated/genai/*.jsonl

data/published/*
!data/published/.gitkeep
!data/published/dashboard/
data/published/dashboard/*
!data/published/dashboard/.gitkeep
!data/published/dashboard/fact_orders_dashboard.csv
!data/published/semantic/
!data/published/semantic/*.parquet
!data/published/semantic/*.csv
!data/published/monitoring/
!data/published/monitoring/*.json
!data/published/monitoring/*.csv

# Optional local-only data
data/external/*
!data/external/.gitkeep
!data/external/genai/
!data/external/genai/*.csv

# Keep screenshots used in the case documentation
!data/screenshots/
!data/screenshots/query_results/
